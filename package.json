{
  "name": "marlin",
  "version": "0.1.0",
  "description": "Smart transaction stack for Solana — Geyser ingest, leader-window detection, Jito bundles with dynamic tips, full lifecycle tracking, one bounded AI decision.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "db:init": "tsx src/db/init.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "agent:smoke": "tsx scripts/agentSmoke.ts",
    "run:batch": "tsx scripts/runBatch.ts",
    "demo": "tsx scripts/demo.ts",
    "test:geyser": "tsx scripts/testGeyser.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.3",
    "bs58": "^5.0.0",
    "openai": "^4.0.0",
    "@triton-one/yellowstone-grpc": "1.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jito-ts": "^4.1.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.6",
    "@types/node": "^20.14.12"
  },
  "overrides": {
    "@solana/web3.js": "$@solana/web3.js"
  }
}
