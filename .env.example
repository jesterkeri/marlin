# --- RPC (primary + fallback) — mainnet-beta only (Jito bundles are mainnet-only) ---
RPC_URL=https://api.mainnet-beta.solana.com          # replace with your SolInfra high-perf mainnet RPC
RPC_FALLBACK_URL=https://api.mainnet-beta.solana.com # secondary mainnet provider

# --- Geyser / Yellowstone gRPC (SolInfra-provided endpoint + x-token) ---
GEYSER_URL=https://your-geyser-endpoint:443
GEYSER_TOKEN=your-x-token

# --- Jito Block Engine (region nearest your target leader) ---
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# A keypair (base58 secret) that signs/pays. Use a mainnet key funded with a tiny balance (cents).
PAYER_SECRET_KEY=base58-secret-key

# --- Tip oracle ---
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor
SUBFLOOR_TIP_FRACTION=0.2           # deliberate sub-floor FAILURE tip = live floor × this (never a hardcoded lamport value)

# --- Persistence (local Postgres on the same VPS) ---
DATABASE_URL=postgres://localhost/marlin

# --- AI agent (via OpenRouter — OpenAI-compatible; replaces the Anthropic SDK) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini   # default (forced function-calling); swap to a stronger slug for the judged demo
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Tuning ---
LEADER_LOOKAHEAD_SLOTS=8
MAX_HOLD_WINDOWS=2
MAX_RETRIES=3
TIP_HARD_CAP_LAMPORTS=200000        # ~0.0002 SOL ceiling — keep costs tiny

# --- Dashboard / logging ---
DASHBOARD_PORT=8080
LOG_LEVEL=info
